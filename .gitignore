# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# OS metadata
.DS_Store
Thumbs.db

# Node modules & frontend builds (handled by Frontend/.gitignore but added here for safety)
