.angular/
dist/

# Project-specific ignores
Backend/venv/
Backend/.env
Backend/*.db
Backend/qdrant_data/
Backend/Logs/
Logs/

# Temporary Microsoft Word lock files
~$*.docx
~$*.doc
~$*
